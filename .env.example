# ─────────────────────────────────────────────────────────────────
# .env.example — Copy this to .env and fill in real values.
# NEVER commit .env to Git. Add it to .gitignore immediately.
# ─────────────────────────────────────────────────────────────────

# Generate your encryption key by running:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VAULT_ENCRYPTION_KEY=REPLACE_WITH_GENERATED_FERNET_KEY

# JWT signing secret — any long random string works
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING

# Token expiry in minutes (default: 60)
TOKEN_EXPIRY_MINUTES=60